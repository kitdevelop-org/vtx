using Microsoft.AspNetCore.Builder;
using Microsoft.Extensions.Configuration;
using Microsoft.Extensions.DependencyInjection;
using Microsoft.EntityFrameworkCore;
using Veritix.Plugin.SDK;
using Veritix.Plugin.SDK.Database;
using Veritix.Plugin.SDK.Frontend;
using Veritix.Plugin.SDK.Licensing;
using Veritix.Plugin.{{.PluginId}}.Services;
using Veritix.Plugin.{{.PluginId}}.Data;
{{if eq .LicenseType "Custom"}}using Veritix.Plugin.{{.PluginId}}.Licensing;{{end}}

namespace Veritix.Plugin.{{.PluginId}};

public class {{.PluginId}}Plugin : PluginBase
{
    public override string PluginId => "{{.PluginId}}";
    public override string DisplayName => "{{.DisplayName}}";
    public override string Version => "1.0.0";
    public override string Description => "Módulo de {{.DisplayName}} para Veritix ERP.";
    public override string Author => "{{.Author}}";
    public override string? Icon => "Box";

    /// <summary>
    /// Declaración del Micro-frontend para el Shell de Veritix.
    /// </summary>
    public override IPluginFrontend? Frontend => new InternalPluginFrontend();

    {{if eq .LicenseType "Custom"}}
    /// <summary>
    /// Lógica de licenciamiento personalizada (BYOL).
    /// </summary>
    public override IPluginLicenseValidator? LicenseValidator => new {{.PluginId}}LicenseValidator();
    {{end}}

    public override void ConfigureServices(IServiceCollection services, IConfiguration configuration)
    {
        // 1. Registrar Contexto de Base de Datos (PostgreSQL)
        var connectionString = configuration.GetConnectionString("DefaultConnection");
        services.AddDbContextFactory<{{.PluginId}}DbContext>(options =>
            options.UseNpgsql(connectionString));

        // 2. Registrar Migrador
        services.AddScoped<IPluginMigrator, {{.PluginId}}Migrator>();

        // 3. Registrar Servicios de Negocio
        services.AddScoped<I{{.PluginId}}Service, {{.PluginId}}Service>();
    }

    public override void MapEndpoints(IApplicationBuilder app)
    {
        // El Core de Veritix mapeará automáticamente los controladores 
        // definidos en el namespace de este plugin.
    }

    public override async Task OnInstalledAsync(Guid tenantId, CancellationToken ct = default)
    {
        // Ejecutar migraciones automáticamente al instalar
        // Esto creará el esquema del plugin para el tenant
        await base.OnInstalledAsync(tenantId, ct);
    }

    private class InternalPluginFrontend : IPluginFrontend
    {
        public string RemoteName => "vtx_plugin_{{.PluginIdLower}}";
        public string ExposedModule => "./PluginApp";

        // Rutas que el plugin registra en el React Router del Shell
        public IReadOnlyList<string> Routes => ["/{{.PluginIdLower}}"];

        // Elementos que aparecerán en el menú lateral del Shell
        public IReadOnlyList<PluginNavItem> NavItems => [
            new PluginNavItem 
            { 
                Label = "{{.DisplayName}}", 
                Path = "/{{.PluginIdLower}}", 
                Icon = "Box" 
            }
        ];
    }
}

}

